# Email Configuration for Gmail SMTP
#
# ===== SETUP INSTRUCTIONS =====
#
# 1. ENABLE 2-STEP VERIFICATION
#    - Visit: https://myaccount.google.com/security
#    - Click "2-Step Verification" and follow the prompts.
#
# 2. GENERATE A GOOGLE APP PASSWORD
#    - Visit: https://myaccount.google.com/apppasswords
#    - Choose "Mail" and a device name, then generate the password.
#    - Copy the 16-character App Password (no spaces).
#
# 3. PASTE CREDENTIALS INTO backend/.env
#    - EMAIL_USER: Your full Gmail address
#    - EMAIL_PASS: Your 16-character App Password (without spaces)
#
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
